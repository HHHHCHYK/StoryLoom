@using StoryLoom.Services
@inject ToastService ToastService
@implements IDisposable

@if (!string.IsNullOrEmpty(currentMessage))
{
    <div class="toast-container" @onclick="HideToast">
        <div class="toast-message">
            @currentMessage
        </div>
    </div>
}

@code {
    private string? currentMessage;
    private System.Threading.Timer? timer;

    protected override void OnInitialized()
    {
        ToastService.OnShowToast += ShowToast;
    }

    private void ShowToast(string message)
    {
        InvokeAsync(() =>
        {
            currentMessage = message;
            StateHasChanged();

            timer?.Dispose();
            timer = new System.Threading.Timer(_ => HideToast(), null, 3000, System.Threading.Timeout.Infinite);
        });
    }

    private void HideToast()
    {
        InvokeAsync(() =>
        {
            currentMessage = null;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ToastService.OnShowToast -= ShowToast;
        timer?.Dispose();
    }
}

<style>
    .toast-container {
        position: fixed;
        top: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10000;
        cursor: pointer;
        animation: toastIn var(--motion-normal) var(--ease-out);
    }

    .toast-message {
        background: rgba(9, 12, 14, 0.96);
        color: var(--text-main);
        padding: 12px 18px;
        border-radius: var(--radius-full);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-soft);
        font-size: var(--text-sm);
        text-align: center;
        max-width: 520px;
        word-wrap: break-word;
        letter-spacing: 0.01em;
    }

    @@keyframes toastIn {
        from {
            top: -50px;
            opacity: 0;
        }
        to {
            top: 20px;
            opacity: 1;
        }
    }
</style>
