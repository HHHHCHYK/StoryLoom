@using StoryLoom.Services
@inject ToastService ToastService
@implements IDisposable

@if (!string.IsNullOrEmpty(currentMessage))
{
    <div class="toast-container" @onclick="HideToast">
        <div class="toast-message">
            @currentMessage
        </div>
    </div>
}

@code {
    private string? currentMessage;
    private System.Threading.Timer? timer;

    protected override void OnInitialized()
    {
        ToastService.OnShowToast += ShowToast;
    }

    private void ShowToast(string message)
    {
        InvokeAsync(() =>
        {
            currentMessage = message;
            StateHasChanged();

            timer?.Dispose();
            timer = new System.Threading.Timer(_ => HideToast(), null, 3000, System.Threading.Timeout.Infinite);
        });
    }

    private void HideToast()
    {
        InvokeAsync(() =>
        {
            currentMessage = null;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ToastService.OnShowToast -= ShowToast;
        timer?.Dispose();
    }
}

<style>
    .toast-container {
        position: fixed;
        top: 24px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10000;
        cursor: pointer;
        animation: slideDown 0.16s ease-out;
    }

    .toast-message {
        background-color: rgba(8, 8, 8, 0.96);
        color: #f5f5f5;
        padding: 12px 18px;
        border-radius: 999px;
        border: 1px solid #262626;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
        font-size: 13px;
        text-align: center;
        max-width: 520px;
        word-wrap: break-word;
        letter-spacing: 0.01em;
    }

    @@keyframes slideDown {
        from {
            top: -50px;
            opacity: 0;
        }
        to {
            top: 20px;
            opacity: 1;
        }
    }
</style>
