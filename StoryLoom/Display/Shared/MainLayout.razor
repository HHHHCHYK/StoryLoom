@inherits LayoutComponentBase
@inject StoryLoom.Services.AppControlService AppControl

<div class="app-shell">
    <aside class="app-sidebar">
        <NavMenu @bind-Collapsed="isSidebarCollapsed" />
    </aside>

    <main class="app-main">
        <ToastContainer />
        <div class="app-content">
            @Body
        </div>
    </main>

    <div class="app-close-zone">
        <button class="button-icon app-close-btn" @onclick="CloseApplication" title="关闭 StoryLoom" aria-label="关闭 StoryLoom">×</button>
    </div>
</div>

@code {
    private bool isSidebarCollapsed = false;

    private async Task CloseApplication()
    {
        await AppControl.PerformShutdownAsync();
    }
}

<style>
    .app-shell {
        display: flex;
        width: 100vw;
        height: 100vh;
        position: relative;
        background:
            radial-gradient(circle at top right, rgba(100, 230, 244, 0.04), transparent 24rem),
            var(--bg-root);
    }

    .app-sidebar {
        flex-shrink: 0;
        height: 100vh;
        border-right: 1px solid var(--border-subtle);
        background: linear-gradient(180deg, rgba(7, 9, 11, 0.98), rgba(4, 6, 8, 0.98));
        box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.02);
    }

    .app-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: transparent;
    }

    .app-content {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.01), transparent 12rem);
    }

    .app-close-zone {
        position: absolute;
        top: 18px;
        right: 18px;
        z-index: 9999;
    }

    .app-close-btn {
        width: 36px;
        height: 36px;
        padding: 0;
        border-radius: var(--radius-full);
        background: rgba(10, 12, 14, 0.92);
        color: var(--text-muted);
        font-size: 18px;
        line-height: 1;
        border-color: var(--border-subtle);
        box-shadow: var(--shadow-soft);
    }

    .app-close-btn:hover {
        background: var(--bg-surface-hover);
        color: var(--text-main);
        border-color: var(--border-strong);
    }

    @@media (max-width: 820px) {
        .app-close-zone {
            top: 14px;
            right: 14px;
        }
    }
</style>
