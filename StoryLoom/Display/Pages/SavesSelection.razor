@page "/"
@page "/saves"
@using StoryLoom.Services
@inject ConversationService ConversationService
@inject NavigationManager Nav
@inject LogService Logger

<div class="page-shell saves-page">
    <div class="page-header">
        <div class="page-title-group">
            <span class="page-eyebrow">Library</span>
            <h1 class="page-title">存档选择</h1>
            <p class="page-subtitle">选择已有故事继续写作，或从空白世界开始新的叙事。</p>
        </div>
        <button class="button" @onclick="CreateNewStory">新故事</button>
    </div>

    @if (isLoading)
    {
        <div class="empty-state surface">
            <div class="empty-title">正在加载存档</div>
            <div class="empty-copy">请稍候，正在整理你的故事记录。</div>
        </div>
    }
    else if (Saves == null || !Saves.Any())
    {
        <div class="empty-state surface">
            <div class="empty-title">还没有存档</div>
            <div class="empty-copy">点击右上角的“新故事”，开始创建第一个世界。</div>
        </div>
    }
    else
    {
        <div class="saves-grid">
            @foreach (var save in Saves)
            {
                <div class="save-card @(save.SaveName == ConversationService.CurrentSaveName ? "active" : "")" @onclick="() => LoadSave(save.SaveName)">
                    <div class="card-header">
                        <div class="title-container">
                            <span class="save-title" title="@save.Title">@save.Title</span>
                            @if (save.SaveName == ConversationService.CurrentSaveName)
                            {
                                <span class="active-badge">当前</span>
                            }
                        </div>
                        
                        @if (save.SaveName != ConversationService.CurrentSaveName)
                        {
                            <button class="delete-save-btn" title="删除存档" @onclick="() => DeleteSave(save.SaveName)" @onclick:stopPropagation="true">
                                删除存档
                            </button>
                        }
                    </div>
                    <div class="save-time">@save.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="save-summary">
                        @(string.IsNullOrWhiteSpace(save.Summary) ? "暂无摘要" : save.Summary)
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<SaveMetadata>? Saves;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        Logger.Log("Opening Saves Selection...");
        
        // Auto-save the current state before loading the list so we don't lose progress on switch
        if (!string.IsNullOrEmpty(ConversationService.CurrentSaveName))
        {
            await ConversationService.SaveCurrentStateAsync();
        }

        await LoadSaveList();
    }

    private async Task LoadSaveList()
    {
        isLoading = true;
        Saves = await ConversationService.GetAvailableSavesAsync();
        isLoading = false;
    }

    private async Task LoadSave(string saveName)
    {
        // Save current one just in case
        if (!string.IsNullOrEmpty(ConversationService.CurrentSaveName) && ConversationService.CurrentSaveName != saveName)
        {
            await ConversationService.SaveCurrentStateAsync();
        }
        
        await ConversationService.LoadSaveAsync(saveName);
        Nav.NavigateTo("story-generator");
    }

    private async Task CreateNewStory()
    {
        await ConversationService.StartNewConversationAsync();
        Nav.NavigateTo("world-building");
    }

    private async Task DeleteSave(string saveName)
    {
        // Add a slight confirmation (optional, currently direct delete)
        await ConversationService.DeleteSaveAsync(saveName);
        await LoadSaveList(); // Refresh the grid
    }
}

<style>
    .saves-page {
        height: 100%;
    }

    .empty-state {
        min-height: 220px;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 32px;
    }

    .empty-title {
        font-size: 20px;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .empty-copy {
        margin-top: 8px;
        max-width: 420px;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .saves-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 18px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .save-card {
        background: #0e0e0e;
        border: 1px solid #202020;
        border-radius: 18px;
        padding: 18px;
        cursor: pointer;
        transition: border-color 120ms ease, background-color 120ms ease, transform 120ms ease;
        display: flex;
        flex-direction: column;
        min-height: 184px;
    }

    .save-card:hover {
        background: #131313;
        border-color: #3b3b3b;
        transform: translateY(-1px);
    }

    .save-card.active {
        background: #ffffff;
        border-color: #ffffff;
        color: #000000;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 10px;
    }

    .title-container {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        overflow: hidden;
    }

    .save-title {
        font-weight: 700;
        font-size: 18px;
        letter-spacing: -0.02em;
        line-height: 1.25;
        display: -webkit-box;
        overflow: hidden;
        text-overflow: ellipsis;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .active-badge {
        border: 1px solid rgba(0, 0, 0, 0.16);
        color: #000000;
        background: rgba(0, 0, 0, 0.06);
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 999px;
        white-space: nowrap;
    }

    .save-time {
        font-size: 12px;
        color: #7f7f7f;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    .save-summary {
        font-size: 14px;
        color: #b6b6b6;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 5;
        -webkit-box-orient: vertical;
        line-height: 1.65;
        margin-top: auto;
    }

    .save-card.active .save-time,
    .save-card.active .save-summary {
        color: rgba(0, 0, 0, 0.68);
    }

    .delete-save-btn {
        min-height: 34px;
        border-radius: 999px;
        border: 1px solid rgba(255, 90, 90, 0.28);
        background: transparent;
        color: #ff7b7b;
        cursor: pointer;
        padding: 0 12px;
        font-size: 12px;
        transition: background-color 120ms ease, border-color 120ms ease, color 120ms ease;
    }

    .delete-save-btn:hover {
        background-color: rgba(255, 90, 90, 0.08);
        border-color: rgba(255, 90, 90, 0.52);
        color: #ff9d9d;
    }

    @@media (max-width: 820px) {
        .saves-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
