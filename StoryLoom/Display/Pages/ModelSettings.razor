@page "/settings"
@using StoryLoom.Agents.Core
@using StoryLoom.Services
@inject SettingsService Settings
@inject LlmService Llm
@inject LogService Logger
@inject StoryAgentManager StoryAgentManager

<div class="page-shell settings-page">
    <div class="page-header">
        <div class="page-title-group">
            <span class="page-eyebrow">Settings</span>
            <h1 class="page-title">模型设置</h1>
            <p class="page-subtitle">配置生成模型、提示模型和写作行为参数。</p>
        </div>
    </div>

    <div class="segmented-control surface">
        <button type="button" class="@GetTabClass(SettingsTab.Models)" @onclick="() => SelectTab(SettingsTab.Models)">模型设置</button>
        <button type="button" class="@GetTabClass(SettingsTab.Generation)" @onclick="() => SelectTab(SettingsTab.Generation)">故事生成设置</button>
        <button type="button" class="@GetTabClass(SettingsTab.Advanced)" @onclick="() => SelectTab(SettingsTab.Advanced)">高级</button>
    </div>

    <div class="settings-grid">
        @if (SelectedTab == SettingsTab.Models)
        {
        <section class="settings-section surface">
            <div class="section-title-row">
                <h3>正文模型</h3>
                <span class="section-note">负责故事正文生成</span>
            </div>
            <div class="form-group">
                <label>模型名称</label>
                <input class="field" @bind="Settings.StoryModelName" @onfocusout="Settings.NotifyStateChanged" placeholder="e.g. deepseek-chat" />
            </div>
            <div class="form-group">
                <label>API Endpoint URL</label>
                <input class="field" @bind="Settings.StoryApiUrl" @onfocusout="Settings.NotifyStateChanged" placeholder="https://api.deepseek.com/v1" />
            </div>
            <div class="form-group">
                <label>正文模型 API Key</label>
                <input class="field" type="password" @bind="Settings.StoryApiKey" @bind:after="Settings.NotifyStateChanged" placeholder="Story model API Key" />
            </div>
            <div class="action-bar-small">
                <button class="button-ghost btn-secondary" @onclick="() => TestConnection(false)" disabled="@(IsTestingStory)">
                    @(IsTestingStory ? "测试中..." : "测试正文模型")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(TestResultStory))
            {
                <div class="test-result @(TestSuccessStory ? "success" : "error")">@TestResultStory</div>
            }
        </section>

        <section class="settings-section surface">
            <div class="section-title-row">
                <h3>提示模型</h3>
                <span class="section-note">负责建议与提示优化</span>
            </div>
            <div class="form-group">
                <label>模型名称</label>
                <input class="field" @bind="Settings.PromptModelName" @onfocusout="Settings.NotifyStateChanged" placeholder="e.g. deepseek-chat" />
            </div>
            <div class="form-group">
                <label>API Endpoint URL</label>
                <input class="field" @bind="Settings.PromptApiUrl" @onfocusout="Settings.NotifyStateChanged" placeholder="https://api.deepseek.com/v1" />
            </div>
            <div class="form-group">
                <label>提示模型 API Key</label>
                <input class="field" type="password" @bind="Settings.PromptApiKey" @bind:after="Settings.NotifyStateChanged" placeholder="Prompt model API Key" />
            </div>
            <div class="action-bar-small">
                <button class="button-ghost btn-secondary" @onclick="() => TestConnection(true)" disabled="@(IsTestingPrompt)">
                    @(IsTestingPrompt ? "测试中..." : "测试提示模型")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(TestResultPrompt))
            {
                <div class="test-result @(TestSuccessPrompt ? "success" : "error")">@TestResultPrompt</div>
            }
        </section>

        <section class="settings-section surface">
            <div class="section-title-row">
                <h3>实体解析模型</h3>
                <span class="section-note">后台解析对话中的角色、物品、势力和场景</span>
            </div>
            <div class="form-group">
                <label>模型名称</label>
                <input class="field" @bind="Settings.EntityParserModelName" @onfocusout="Settings.NotifyStateChanged" placeholder="e.g. deepseek-chat" />
            </div>
            <div class="form-group">
                <label>API Endpoint URL</label>
                <input class="field" @bind="Settings.EntityParserApiUrl" @onfocusout="Settings.NotifyStateChanged" placeholder="https://api.deepseek.com/v1" />
            </div>
            <div class="form-group">
                <label>实体解析 API Key</label>
                <input class="field" type="password" @bind="Settings.EntityParserApiKey" @bind:after="Settings.NotifyStateChanged" placeholder="Entity parser API Key" />
            </div>
            <div class="action-bar-small">
                <button class="button-ghost btn-secondary" @onclick="TestEntityParserConnection" disabled="@(IsTestingEntityParser)">
                    @(IsTestingEntityParser ? "测试中..." : "测试实体解析模型")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(TestResultEntityParser))
            {
                <div class="test-result @(TestSuccessEntityParser ? "success" : "error")">@TestResultEntityParser</div>
            }
        </section>
        }

        @if (SelectedTab == SettingsTab.Generation)
        {
        <div class="settings-stack">
            <section class="settings-group">
                <div class="settings-group-header">
                    <h3 class="settings-group-title">解析实体设置</h3>
                    <p class="settings-group-note">控制故事生成过程中的实体识别和写入行为。</p>
                </div>
                <div class="settings-fields">
                    <div class="form-group inline-check">
                        <label>
                            <input type="checkbox" @bind="Settings.IsEntityParserEnabled" @bind:after="Settings.NotifyStateChanged" />
                            自动解析实体
                        </label>
                    </div>
                    <div class="parser-options">
                        <div class="form-group inline-check">
                            <label class="@(!Settings.IsEntityParserEnabled ? "disabled-option" : "")">
                                <input type="checkbox" @bind="Settings.IsEntityParserBeforeSendEnabled" @bind:after="Settings.NotifyStateChanged" disabled="@(!Settings.IsEntityParserEnabled)" />
                                发送前检测用户输入
                            </label>
                        </div>
                        <div class="form-group inline-check">
                            <label class="@(!Settings.IsEntityParserEnabled ? "disabled-option" : "")">
                                <input type="checkbox" @bind="Settings.IsEntityParserAfterSendEnabled" @bind:after="Settings.NotifyStateChanged" disabled="@(!Settings.IsEntityParserEnabled)" />
                                发送后检测 AI 回复
                            </label>
                        </div>
                    </div>
                    <div class="form-group inline-check">
                        <label class="@(!Settings.IsEntityParserEnabled ? "disabled-option" : "")">
                            <input type="checkbox" @bind="Settings.IsEntityParserAutoApplyEnabled" @bind:after="Settings.NotifyStateChanged" disabled="@(!Settings.IsEntityParserEnabled)" />
                            解析后自动确认并写入世界设定
                        </label>
                    </div>
                </div>
            </section>

            <section class="settings-group">
                <div class="settings-group-header">
                    <h3 class="settings-group-title">打字机速度</h3>
                    <p class="settings-group-note">控制 AI 回复逐字显示的节奏。</p>
                </div>
                <div class="settings-fields">
                    <div class="form-group">
                        <label>打字机速度 (ms): @Settings.TextSpeed</label>
                        <input class="field" type="number" min="1" max="500" @bind="Settings.TextSpeed" @onfocusout="Settings.NotifyStateChanged" />
                    </div>
                </div>
            </section>
        </div>
        }

        @if (SelectedTab == SettingsTab.Advanced)
        {
        <div class="settings-stack">
            <section class="settings-group">
                <div class="settings-group-header">
                    <h3 class="settings-group-title">生成参数</h3>
                    <p class="settings-group-note">高级生成控制，通常保持默认即可。</p>
                </div>
                <div class="settings-fields">
                    <div class="form-group">
                        <label>模型温度: @Settings.Temperature</label>
                        <input class="field-range" type="range" min="0" max="1" step="0.1" @bind="Settings.Temperature" @onmouseup="Settings.NotifyStateChanged" />
                    </div>
                    <div class="form-group">
                        <label>上下文窗口: @Settings.MaxContextWindow</label>
                        <input class="field" type="number" @bind="Settings.MaxContextWindow" @onfocusout="Settings.NotifyStateChanged" />
                    </div>
                    <div class="form-group">
                        <label>总结阈值: @Settings.SummaryTokenThreshold</label>
                        <input class="field" type="number" step="100" @bind="Settings.SummaryTokenThreshold" @onfocusout="Settings.NotifyStateChanged" />
                    </div>
                </div>
            </section>

            <section class="settings-group">
                <div class="settings-group-header">
                    <h3 class="settings-group-title">兼容配置</h3>
                    <p class="settings-group-note">用于兼容旧配置文件中的全局密钥。</p>
                </div>
                <div class="settings-fields">
                    <div class="form-group">
                        <label>旧版全局 API Key</label>
                        <input class="field" type="password" @bind="Settings.ApiKey" @onfocusout="Settings.NotifyStateChanged" placeholder="Legacy API Key" />
                    </div>
                </div>
            </section>

            <section class="settings-group">
                <div class="settings-group-header">
                    <h3 class="settings-group-title">Agent 测试</h3>
                    <p class="settings-group-note">打开内部 Agent 测试面板，检查当前 Agent 是否可运行。</p>
                </div>
                <div class="settings-fields">
                    <div class="action-bar-small">
                        <button type="button" class="button-ghost btn-secondary" @onclick="OpenAgentTestDialog">打开 Agent 测试</button>
                    </div>
                </div>
            </section>
        </div>
        }
    </div>
</div>

@if (ShowAgentTestDialog)
{
    <div class="agent-test-overlay" @onclick="CloseAgentTestDialog">
        <div class="agent-test-modal" @onclick:stopPropagation>
            <div class="agent-test-header">
                <div>
                    <span class="page-eyebrow">Agent Lab</span>
                    <h3>内部 Agent 测试</h3>
                    <p>当前面板用于旁路测试 Agent 状态，不会影响正式故事生成。</p>
                </div>
                <button type="button" class="button-icon" @onclick="CloseAgentTestDialog" aria-label="关闭 Agent 测试">×</button>
            </div>

            <div class="agent-test-actions">
                <button type="button" class="button" @onclick="RunAllAgentTestsAsync" disabled="@IsTestingAgents">
                    @(IsTestingAgents ? "测试中..." : "测试全部 Agent")
                </button>
            </div>

            <div class="agent-test-list">
                @foreach (var result in AgentTestResults)
                {
                    <div class="agent-test-row @(result.Status == AgentTestStatus.Success ? "success" : result.Status == AgentTestStatus.Failed ? "failed" : "idle")">
                        <div>
                            <div class="agent-test-name">@result.Name</div>
                            <div class="agent-test-message">@result.Message</div>
                        </div>
                        <span>@GetAgentTestStatusText(result.Status)</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private SettingsTab SelectedTab = SettingsTab.Models;

    private bool IsTestingStory = false;
    private string TestResultStory = "";
    private bool TestSuccessStory = false;

    private bool IsTestingPrompt = false;
    private string TestResultPrompt = "";
    private bool TestSuccessPrompt = false;

    private bool IsTestingEntityParser = false;
    private string TestResultEntityParser = "";
    private bool TestSuccessEntityParser = false;
    private bool ShowAgentTestDialog = false;
    private bool IsTestingAgents = false;
    private List<AgentTestViewModel> AgentTestResults = [];

    /// <summary>
    /// 测试与 LLM API 的连接，并根据结果更新 UI。
    /// </summary>
    private async Task TestConnection(bool isPrompt)
    {
        Logger.Log($"User initiated connection test for {(isPrompt ? "Prompt" : "Story")} Model.");
        if (isPrompt)
        {
            IsTestingPrompt = true;
            TestResultPrompt = "";
        }
        else
        {
            IsTestingStory = true;
            TestResultStory = "";
        }

        try
        {
            var response = await Llm.TestConnectionAsync(isPrompt);
            if (isPrompt)
            {
                TestSuccessPrompt = true;
                TestResultPrompt = "连接成功: " + response;
            }
            else
            {
                TestSuccessStory = true;
                TestResultStory = "连接成功: " + response;
            }
            Logger.Log($"Connection test UI reported success for {(isPrompt ? "Prompt" : "Story")} Model.");
        }
        catch (Exception ex)
        {
            if (isPrompt)
            {
                TestSuccessPrompt = false;
                TestResultPrompt = "连接失败: " + ex.Message;
            }
            else
            {
                TestSuccessStory = false;
                TestResultStory = "连接失败: " + ex.Message;
            }
            Logger.LogError(ex, "ModelSettings.TestConnection");
        }
        finally
        {
            if (isPrompt) IsTestingPrompt = false;
            else IsTestingStory = false;
        }
    }

    private async Task TestEntityParserConnection()
    {
        Logger.Log("User initiated connection test for Entity Parser Model.");
        IsTestingEntityParser = true;
        TestResultEntityParser = "";

        try
        {
            var response = await Llm.TestConnectionAsync(LlmModelRole.EntityParser);
            TestSuccessEntityParser = true;
            TestResultEntityParser = "连接成功: " + response;
            Logger.Log("Connection test UI reported success for Entity Parser Model.");
        }
        catch (Exception ex)
        {
            TestSuccessEntityParser = false;
            TestResultEntityParser = "连接失败: " + ex.Message;
            Logger.LogError(ex, "ModelSettings.TestEntityParserConnection");
        }
        finally
        {
            IsTestingEntityParser = false;
        }
    }

    private void SelectTab(SettingsTab tab)
    {
        SelectedTab = tab;
        Logger.Log($"Settings tab selected: {tab}");
    }

    private string GetTabClass(SettingsTab tab) => SelectedTab == tab ? "segmented-option active" : "segmented-option";

    private void OpenAgentTestDialog()
    {
        AgentTestResults = StoryAgentManager.ListAgents()
            .Select(agent => new AgentTestViewModel(agent.Name, agent.Type))
            .ToList();
        ShowAgentTestDialog = true;
    }

    private void CloseAgentTestDialog()
    {
        if (IsTestingAgents)
        {
            return;
        }

        ShowAgentTestDialog = false;
    }

    private async Task RunAllAgentTestsAsync()
    {
        IsTestingAgents = true;

        for (var i = 0; i < AgentTestResults.Count; i++)
        {
            var viewModel = AgentTestResults[i];
            viewModel.Status = AgentTestStatus.Running;
            viewModel.Message = "正在测试...";
            StateHasChanged();

            var result = await StoryAgentManager.RunAsync(viewModel.Type, options: new StoryAgentRunOptions { DryRun = false });
            viewModel.Status = result.Success ? AgentTestStatus.Success : AgentTestStatus.Failed;
            viewModel.Message = result.Success ? result.Summary : result.ErrorMessage ?? "测试失败";
        }

        IsTestingAgents = false;
    }

    private static string GetAgentTestStatusText(AgentTestStatus status) => status switch
    {
        AgentTestStatus.Idle => "待测试",
        AgentTestStatus.Running => "运行中",
        AgentTestStatus.Success => "通过",
        AgentTestStatus.Failed => "失败",
        _ => "未知"
    };

    private enum SettingsTab
    {
        Models,
        Generation,
        Advanced
    }

    private enum AgentTestStatus
    {
        Idle,
        Running,
        Success,
        Failed
    }

    private class AgentTestViewModel
    {
        public string Name { get; }
        public StoryAgentType Type { get; }
        public AgentTestStatus Status { get; set; }
        public string Message { get; set; } = "等待测试";

        public AgentTestViewModel(string name, StoryAgentType type)
        {
            Name = name;
            Type = type;
        }
    }
}

<style>
    .settings-page {
        height: 100%;
        overflow-y: auto;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .inline-check label {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
        font-weight: 500;
    }

    .inline-check input {
        accent-color: var(--accent);
    }

    .parser-options {
        display: grid;
        gap: 10px;
        padding: 12px 14px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid var(--border-subtle);
    }

    .disabled-option {
        opacity: 0.48;
    }

    .settings-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .settings-section,
    .developer-mode {
        padding: 20px;
    }

    label {
        color: #d4d4d4;
        font-size: 13px;
        font-weight: 600;
    }

    .test-result {
        padding: 14px 16px;
        border-radius: 16px;
        background-color: #0b0b0b;
        border: 1px solid #202020;
        white-space: pre-wrap;
        line-height: 1.6;
    }

    .test-result.success {
        border-color: rgba(255, 255, 255, 0.26);
        color: #f5f5f5;
    }

    .test-result.error {
        border-color: rgba(255, 90, 90, 0.5);
        color: #ffd9d9;
    }

    .action-bar-small {
        margin-top: 4px;
    }

    .btn-secondary {
        min-width: 132px;
    }

    .field-range {
        min-height: 42px;
        padding: 0;
        accent-color: #ffffff;
    }

    .agent-test-overlay {
        position: fixed;
        inset: 0;
        z-index: 1200;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px;
        background: rgba(0, 0, 0, 0.62);
    }

    .agent-test-modal {
        width: min(720px, 100%);
        max-height: min(720px, 88vh);
        display: flex;
        flex-direction: column;
        border-radius: 20px;
        border: 1px solid var(--border-strong);
        background: var(--bg-surface);
        box-shadow: var(--shadow-elevated);
        overflow: hidden;
    }

    .agent-test-header {
        display: flex;
        justify-content: space-between;
        gap: 18px;
        padding: 22px 24px;
        border-bottom: 1px solid var(--border-subtle);
    }

    .agent-test-header h3 {
        margin: 6px 0 6px;
        font-size: 20px;
        line-height: 1.2;
    }

    .agent-test-header p {
        margin: 0;
        color: var(--text-muted);
        font-size: 13px;
    }

    .agent-test-actions {
        padding: 16px 24px;
        border-bottom: 1px solid var(--border-subtle);
    }

    .agent-test-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow-y: auto;
        padding: 18px 24px 24px;
    }

    .agent-test-row {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 16px;
        border-radius: 14px;
        border: 1px solid var(--border-subtle);
        background: var(--bg-input);
    }

    .agent-test-row.success {
        border-color: rgba(143, 240, 176, 0.32);
        background: var(--success-soft);
    }

    .agent-test-row.failed {
        border-color: rgba(255, 107, 122, 0.34);
        background: var(--danger-soft);
    }

    .agent-test-name {
        font-weight: 800;
        color: var(--text-main);
    }

    .agent-test-message {
        margin-top: 4px;
        color: var(--text-muted);
        font-size: 13px;
        line-height: 1.5;
    }

    .agent-test-row > span {
        flex: 0 0 auto;
        color: var(--text-muted);
        font-size: 12px;
        font-weight: 700;
    }

    @@media (max-width: 980px) {
        .settings-grid {
            grid-template-columns: 1fr;
        }

    }
</style>
