@page "/settings"
@inject SettingsService Settings
@inject LlmService Llm
@inject LogService Logger

<div class="settings-page">
    <h2>⚙️ 模型设置 (Model Settings)</h2>

    <div class="section-title">📝 正文模型 (Story Model)</div>
    <div class="form-group">
        <label>模型名称 (Model Name)</label>
        <input @bind="Settings.StoryModelName" @onfocusout="Settings.NotifyStateChanged" placeholder="e.g. deepseek-chat" />
    </div>
    <div class="form-group">
        <label>API Endpoint URL</label>
        <input @bind="Settings.StoryApiUrl" @onfocusout="Settings.NotifyStateChanged" placeholder="https://api.deepseek.com/v1" />
    </div>
    <div class="action-bar-small">
        <button class="btn-secondary" @onclick="() => TestConnection(false)" disabled="@(IsTestingStory)">
            @(IsTestingStory ? "Testing..." : "Test Story Model")
        </button>
    </div>
    @if (!string.IsNullOrEmpty(TestResultStory))
    {
        <div class="test-result @(TestSuccessStory ? "success" : "error")">
            @TestResultStory
        </div>
    }

    <hr class="sub-divider" />

    <div class="section-title">💡 提示模型 (Prompt Model)</div>
    <div class="form-group">
        <label>模型名称 (Model Name)</label>
        <input @bind="Settings.PromptModelName" @onfocusout="Settings.NotifyStateChanged" placeholder="e.g. deepseek-chat" />
    </div>
    <div class="form-group">
        <label>API Endpoint URL</label>
        <input @bind="Settings.PromptApiUrl" @onfocusout="Settings.NotifyStateChanged" placeholder="https://api.deepseek.com/v1" />
    </div>
    <div class="action-bar-small">
        <button class="btn-secondary" @onclick="() => TestConnection(true)" disabled="@(IsTestingPrompt)">
            @(IsTestingPrompt ? "Testing..." : "Test Prompt Model")
        </button>
    </div>
    @if (!string.IsNullOrEmpty(TestResultPrompt))
    {
        <div class="test-result @(TestSuccessPrompt ? "success" : "error")">
            @TestResultPrompt
        </div>
    }

    <hr class="sub-divider" />

    <div class="form-group">
        <label>全局 API Key (Global API Key)</label>
        <input type="password" @bind="Settings.ApiKey" @onfocusout="Settings.NotifyStateChanged" placeholder="Your Global API Key" />
    </div>

    <div class="form-group">
                    <label>打字机速度 (Text Speed ms): @Settings.TextSpeed</label>
                    <input type="number" min="1" max="500" @bind="Settings.TextSpeed" @onfocusout="Settings.NotifyStateChanged" />
                </div>

    <hr />

    <div class="developer-mode">
        <div class="dev-header" @onclick="ToggleDevMode">
             <span class="arrow">@(ShowDevMode ? "▼" : "▶")</span> 开发者模式 (Developer Mode)
        </div>

        @if (ShowDevMode)
        {
            <div class="dev-content">
                <div class="form-group">
                    <label>模型温度 (Temperature): @Settings.Temperature</label>
                    <input type="range" min="0" max="1" step="0.1" @bind="Settings.Temperature" @onmouseup="Settings.NotifyStateChanged" />
                </div>

                <div class="form-group">
                    <label>上下文窗口 (Context Window): @Settings.MaxContextWindow</label>
                     <input type="number" @bind="Settings.MaxContextWindow" @onfocusout="Settings.NotifyStateChanged" />
                </div>

                <div class="form-group">
                    <label>总结阈值 (Summary Token Threshold): @Settings.SummaryTokenThreshold</label>
                     <input type="number" step="100" @bind="Settings.SummaryTokenThreshold" @onfocusout="Settings.NotifyStateChanged" />
                </div>

                
            </div>
        }
    </div>
</div>

@code {
    private bool IsTestingStory = false;
    private string TestResultStory = "";
    private bool TestSuccessStory = false;

    private bool IsTestingPrompt = false;
    private string TestResultPrompt = "";
    private bool TestSuccessPrompt = false;

    private bool ShowDevMode = false;

    /// <summary>
    /// 测试与 LLM API 的连接，并根据结果更新 UI。
    /// </summary>
    private async Task TestConnection(bool isPrompt)
    {
        Logger.Log($"User initiated connection test for {(isPrompt ? "Prompt" : "Story")} Model.");
        if (isPrompt)
        {
            IsTestingPrompt = true;
            TestResultPrompt = "";
        }
        else
        {
            IsTestingStory = true;
            TestResultStory = "";
        }

        try
        {
            var response = await Llm.TestConnectionAsync(isPrompt);
            if (isPrompt)
            {
                TestSuccessPrompt = true;
                TestResultPrompt = "✅ " + response;
            }
            else
            {
                TestSuccessStory = true;
                TestResultStory = "✅ " + response;
            }
            Logger.Log($"Connection test UI reported success for {(isPrompt ? "Prompt" : "Story")} Model.");
        }
        catch (Exception ex)
        {
            if (isPrompt)
            {
                TestSuccessPrompt = false;
                TestResultPrompt = "❌ Error: " + ex.Message;
            }
            else
            {
                TestSuccessStory = false;
                TestResultStory = "❌ Error: " + ex.Message;
            }
            Logger.LogError(ex, "ModelSettings.TestConnection");
        }
        finally
        {
            if (isPrompt) IsTestingPrompt = false;
            else IsTestingStory = false;
        }
    }

    private void ToggleDevMode() 
    {
        ShowDevMode = !ShowDevMode;
        Logger.Log($"Developer mode toggled: {ShowDevMode}");
    }
}

<style>
    .settings-page {
        max-width: 600px;
        margin: 0 auto;
    }

    /* Layout */
    .settings-container {
        display: flex;
        flex-direction: column;
        flex: 1;
        height: 100%;
        background-color: #1e1e1e;
        margin-bottom: 5px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 15px;
        display: flex;
        flex-direction: column;
    }

    label {
        color: #9cdcfe;
        margin-bottom: 5px;
        font-size: 14px;
    }

    input[type="text"], input[type="password"], input[type="number"] {
        background-color: #3c3c3c;
        color: #d4d4d4;
        border: 1px solid #555;
        padding: 8px;
        border-radius: 4px;
    }

    .btn-primary {
         background-color: #0e639c;
         color: white;
         border: none;
         padding: 10px 20px;
         border-radius: 4px;
         cursor: pointer;
    }

    .btn-primary:disabled {
        background-color: #555;
        cursor: not-allowed;
    }

    .test-result {
        margin-top: 15px;
        padding: 10px;
        border-radius: 4px;
        background-color: #2d2d30;
        white-space: pre-wrap;
    }

    .test-result.success { border-left: 4px solid #4CAF50; }
    .test-result.error { border-left: 4px solid #f44336; }

    .section-title {
        font-size: 16px;
        font-weight: bold;
        color: #dcdcaa;
        margin-bottom: 10px;
        margin-top: 10px;
    }

    .sub-divider {
        border: 0;
        height: 1px;
        background: #3e3e42;
        margin: 20px 0;
    }

    .action-bar-small {
        margin-bottom: 10px;
    }

    .btn-secondary {
         background-color: #333333;
         color: #d4d4d4;
         border: 1px solid #555;
         padding: 6px 12px;
         border-radius: 4px;
         cursor: pointer;
    }

    .btn-secondary:hover {
        background-color: #444444;
    }

    .btn-secondary:disabled {
        background-color: #222;
        color: #666;
        cursor: not-allowed;
    }

    .developer-mode {
        margin-top: 20px;
        border: 1px solid #3e3e42;
        border-radius: 4px;
        overflow: hidden;
    }

    .dev-header {
        background-color: #252526;
        padding: 10px;
        cursor: pointer;
        user-select: none;
    }

    .dev-content {
        padding: 15px;
        background-color: #1e1e1e;
    }
</style>
