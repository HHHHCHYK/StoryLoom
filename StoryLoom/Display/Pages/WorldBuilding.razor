@page "/world-building"
@using StoryLoom.Data.Models
@inject SettingsService Settings
@inject ConversationService ConversationService
@inject LlmService Llm
@inject NavigationManager Nav
@inject LogService Logger

<div class="page-shell world-building">
    <div class="page-header">
        <div class="page-title-group">
            <span class="page-eyebrow">World</span>
            <h1 class="page-title">世界构建</h1>
            <p class="page-subtitle">先定义世界背景与主角，再补充角色、势力、物品和场景。</p>
        </div>
        @if (IsEnhancing)
        {
            <span class="status-pill">AI 正在整理设定</span>
        }
    </div>
    
    @if (!Settings.IsModelConfigured)
    {
        <div class="alert-warning">
            尚未配置模型信息。请前往 <a href="settings">设置页面</a> 配置 API Key。
        </div>
    }

    <div class="split-container">
        <div class="section-box surface">
            <div class="section-title-row">
                <h3>背景设定</h3>
                <span class="section-note">世界观、规则、时代、冲突</span>
            </div>
            <textarea class="field-area section-textarea" @bind="Settings.Background" @onfocusout="SaveWorldSettings" disabled="@IsBackgroundLocked" rows="10" placeholder="描述你的故事世界观..."></textarea>
            <div class="controls">
                <button class="button-ghost icon-btn" @onclick="() => IsBackgroundLocked = !IsBackgroundLocked" title="Lock/Unlock">
                    @(IsBackgroundLocked ? "已锁定" : "可编辑")
                </button>
                <div class="right-controls">
                     <button class="button-ghost icon-btn" @onclick="UndoBackground" title="Undo">撤销</button>
                     <button class="button ai-btn" @onclick="EnhanceBackground" disabled="@(IsBackgroundLocked || IsEnhancing)">
                        AI 完善
                     </button>
                </div>
            </div>
        </div>

        <div class="section-box surface">
            <div class="section-title-row">
                <h3>主角设定</h3>
                <span class="section-note">动机、个性、经历、目标</span>
            </div>
            <textarea class="field-area section-textarea" @bind="Settings.Protagonist" @onfocusout="SaveWorldSettings" disabled="@IsProtagonistLocked" rows="10" placeholder="描述主角的性格、外貌..."></textarea>
            <div class="controls">
                <button class="button-ghost icon-btn" @onclick="() => IsProtagonistLocked = !IsProtagonistLocked" title="Lock/Unlock">
                    @(IsProtagonistLocked ? "已锁定" : "可编辑")
                </button>
                 <div class="right-controls">
                     <button class="button-ghost icon-btn" @onclick="UndoProtagonist" title="Undo">撤销</button>
                     <button class="button ai-btn" @onclick="EnhanceProtagonist" disabled="@(IsProtagonistLocked || IsEnhancing)">
                        AI 完善
                     </button>
                </div>
            </div>
        </div>
    </div>
    
    @if (IsEnhancing)
    {
        <div class="loading-overlay">
            <div class="spinner"></div> AI 正在思考...
        </div>
    }

    <div class="cards-section">
        <div class="section-title-row">
            <h3>实体管理</h3>
            <span class="section-note">保持实体名称清晰，摘要短而准。</span>
        </div>
        
        <div class="entity-category surface">
            <div class="category-header">
                <h4>角色</h4>
                <button class="button-ghost btn-add" @onclick="() => OpenModal(new Character(), EntityType.Character)">新增角色</button>
            </div>
            <div class="cards-grid">
                @foreach (var c in Settings.Characters)
                {
                    <div class="entity-card" @onclick="() => OpenModal(c, EntityType.Character)">
                        <div class="card-name">@(string.IsNullOrWhiteSpace(c.Name) ? "未命名角色" : c.Name)</div>
                        <div class="card-summary">@(string.IsNullOrWhiteSpace(c.Summary) ? "暂无简介" : c.Summary)</div>
                    </div>
                }
            </div>
        </div>

        <div class="entity-category surface">
            <div class="category-header">
                <h4>势力</h4>
                <button class="button-ghost btn-add" @onclick="() => OpenModal(new Faction(), EntityType.Faction)">新增势力</button>
            </div>
            <div class="cards-grid">
                @foreach (var f in Settings.Factions)
                {
                    <div class="entity-card" @onclick="() => OpenModal(f, EntityType.Faction)">
                        <div class="card-name">@(string.IsNullOrWhiteSpace(f.Name) ? "未命名势力" : f.Name)</div>
                        <div class="card-summary">@(string.IsNullOrWhiteSpace(f.Summary) ? "暂无简介" : f.Summary)</div>
                    </div>
                }
            </div>
        </div>

        <div class="entity-category surface">
            <div class="category-header">
                <h4>物品</h4>
                <button class="button-ghost btn-add" @onclick="() => OpenModal(new Item(), EntityType.Item)">新增物品</button>
            </div>
            <div class="cards-grid">
                @foreach (var i in Settings.Items)
                {
                    <div class="entity-card" @onclick="() => OpenModal(i, EntityType.Item)">
                        <div class="card-name">@(string.IsNullOrWhiteSpace(i.Name) ? "未命名物品" : i.Name)</div>
                        <div class="card-summary">@(string.IsNullOrWhiteSpace(i.Summary) ? "暂无简介" : i.Summary)</div>
                    </div>
                }
            </div>
        </div>

        <div class="entity-category surface">
            <div class="category-header">
                <h4>场景</h4>
                <button class="button-ghost btn-add" @onclick="() => OpenModal(new Scene(), EntityType.Scene)">新增场景</button>
            </div>
            <div class="cards-grid">
                @foreach (var s in Settings.Scenes)
                {
                    <div class="entity-card" @onclick="() => OpenModal(s, EntityType.Scene)">
                        <div class="card-name">@(string.IsNullOrWhiteSpace(s.Name) ? "未命名场景" : s.Name)</div>
                        <div class="card-summary">@(string.IsNullOrWhiteSpace(s.Summary) ? "暂无简介" : s.Summary)</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (IsModalOpen)
    {
        <div class="modal-overlay" @onclick="CloseModal">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>编辑 @GetEntityTypeName(ActiveEntityType)</h3>
                    <button class="close-btn" @onclick="CloseModal">关闭</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>名称</label>
                        <input class="field" type="text" @bind="ActiveEntityName" />
                    </div>
                    <div class="form-group">
                        <label>简介</label>
                        <textarea class="field-area" rows="3" @bind="ActiveEntitySummary"></textarea>
                    </div>
                    <div class="form-group">
                        <label>详细描述</label>
                        @for (int i = 0; i < ActiveEntityDescriptions.Count; i++)
                        {
                            var index = i;
                            <div class="desc-row">
                                <textarea class="field-area" rows="2" @bind="ActiveEntityDescriptions[index]"></textarea>
                                <button class="button-danger btn-remove" @onclick="() => ActiveEntityDescriptions.RemoveAt(index)">删除</button>
                            </div>
                        }
                        <button class="button-ghost btn-add-minor" @onclick="() => ActiveEntityDescriptions.Add(string.Empty)">添加描述属性</button>
                    </div>
                </div>
                <div class="modal-footer">
                    @if (!IsNewEntity)
                    {
                        <button class="button-danger btn-delete" @onclick="DeleteEntity">删除</button>
                    }
                    <button class="button btn-save" @onclick="SaveEntity">保存</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // UI 状态标志
    private bool IsBackgroundLocked = false;
    private bool IsProtagonistLocked = false;
    private bool IsEnhancing = false;

    // 简单的撤销栈 (目前仅支持单步撤销)，用于回滚 AI 的修改
    private string LastBackground = "";
    private string LastProtagonist = "";

    protected override void OnInitialized()
    {
        LastBackground = Settings.Background;
        LastProtagonist = Settings.Protagonist;
    }

    /// <summary>
    /// 调用 LLM 服务来润色背景描述。
    /// 处理 UI 状态（加载中、锁定）并记录错误日志。
    /// </summary>
    private async Task EnhanceBackground()
    {
        if (!VerifyConfig()) return;
        
        Logger.Log("User requested background enhancement.");
        IsEnhancing = true;
        LastBackground = Settings.Background; // 保存当前状态以便撤销
        try
        {
            // 调用 LLM 服务，使用 "Background" 作为上下文类型
            Settings.Background = await Llm.EnhanceTextAsync(Settings.Background, "Background");
            await SaveWorldSettings();
        }
        catch (Exception ex) {_ = ex; /* LlmService 会记录日志，UI 只需恢复状态 */ }
        finally
        {
            IsEnhancing = false;
        }
    }

    /// <summary>
    /// 调用 LLM 服务来润色主角描述。
    /// </summary>
    private async Task EnhanceProtagonist()
    {
        if (!VerifyConfig()) return;

        Logger.Log("User requested protagonist enhancement.");
        IsEnhancing = true;
        LastProtagonist = Settings.Protagonist; // 保存状态以便撤销
        try
        {
            Settings.Protagonist = await Llm.EnhanceTextAsync(Settings.Protagonist, "Protagonist");
            await SaveWorldSettings();
        }
        catch (Exception ex) { _ = ex; }
        finally
        {
            IsEnhancing = false;
        }
    }

    private async Task UndoBackground() 
    {
        Logger.Log("User undid background change.");
        Settings.Background = LastBackground;
        await SaveWorldSettings();
    }

    private async Task UndoProtagonist() 
    {
        Logger.Log("User undid protagonist change.");
        Settings.Protagonist = LastProtagonist;
        await SaveWorldSettings();
    }

    private async Task SaveWorldSettings()
    {
        await ConversationService.SaveCurrentStateAsync();
        Logger.Log("World settings saved automatically.");
    }

    /// <summary>
    /// 在尝试 AI 操作前，检查 API 配置是否有效。
    /// 如果配置缺失，将跳转到设置页面。
    /// </summary>
    private bool VerifyConfig()
    {
        if (!Settings.IsModelConfigured)
        {
            Logger.Log("Config verification failed in WorldBuilding. Redirecting to settings.", LogLevel.Warning);
            Nav.NavigateTo("settings");
            return false;
        }
        return true;
    }

    // --- Entity System ---
    private enum EntityType { None, Character, Faction, Item, Scene }
    private bool IsModalOpen = false;
    private EntityType ActiveEntityType = EntityType.None;
    private object? ActiveEntity = null;
    private bool IsNewEntity = false;

    private string ActiveEntityName = "";
    private string ActiveEntitySummary = "";
    private List<string> ActiveEntityDescriptions = new();

    private void OpenModal(object entity, EntityType type)
    {
        ActiveEntity = entity;
        ActiveEntityType = type;
        IsNewEntity = false;

        // Determine if it's new based on collection containment
        if (type == EntityType.Character && !Settings.Characters.Contains((Character)entity)) IsNewEntity = true;
        if (type == EntityType.Faction && !Settings.Factions.Contains((Faction)entity)) IsNewEntity = true;
        if (type == EntityType.Item && !Settings.Items.Contains((Item)entity)) IsNewEntity = true;
        if (type == EntityType.Scene && !Settings.Scenes.Contains((Scene)entity)) IsNewEntity = true;

        dynamic dyn = entity;
        ActiveEntityName = dyn.Name ?? "";
        ActiveEntitySummary = dyn.Summary ?? "";
        
        ActiveEntityDescriptions.Clear();
        if (type == EntityType.Item)
        {
            if (dyn.Description != null) ActiveEntityDescriptions.AddRange(dyn.Description);
        }
        else if (type == EntityType.Faction || type == EntityType.Scene)
        {
            if (dyn.Descriptions != null) ActiveEntityDescriptions.AddRange(dyn.Descriptions);
        }
        else if (type == EntityType.Character)
        {
            if (dyn.Origins != null) ActiveEntityDescriptions.AddRange(dyn.Origins);
        }
        
        IsModalOpen = true;
    }

    private async Task SaveEntity()
    {
        if (ActiveEntity == null) return;
        dynamic dyn = ActiveEntity;
        dyn.Name = ActiveEntityName;
        dyn.Summary = ActiveEntitySummary;

        if (ActiveEntityType == EntityType.Item)
            dyn.Description = new List<string>(ActiveEntityDescriptions);
        else if (ActiveEntityType == EntityType.Faction || ActiveEntityType == EntityType.Scene)
            dyn.Descriptions = new List<string>(ActiveEntityDescriptions);
        else if (ActiveEntityType == EntityType.Character)
            dyn.Origins = new List<string>(ActiveEntityDescriptions);

        // Add if new
        if (IsNewEntity)
        {
            if (ActiveEntityType == EntityType.Character) Settings.Characters.Add((Character)ActiveEntity);
            if (ActiveEntityType == EntityType.Faction) Settings.Factions.Add((Faction)ActiveEntity);
            if (ActiveEntityType == EntityType.Item) Settings.Items.Add((Item)ActiveEntity);
            if (ActiveEntityType == EntityType.Scene) Settings.Scenes.Add((Scene)ActiveEntity);
        }

        await SaveWorldSettings();
        CloseModal();
    }

    private async Task DeleteEntity()
    {
        if (ActiveEntity == null) return;
        
        if (ActiveEntityType == EntityType.Character) Settings.Characters.Remove((Character)ActiveEntity);
        if (ActiveEntityType == EntityType.Faction) Settings.Factions.Remove((Faction)ActiveEntity);
        if (ActiveEntityType == EntityType.Item) Settings.Items.Remove((Item)ActiveEntity);
        if (ActiveEntityType == EntityType.Scene) Settings.Scenes.Remove((Scene)ActiveEntity);

        await SaveWorldSettings();
        CloseModal();
    }

    private void CloseModal()
    {
        IsModalOpen = false;
        ActiveEntity = null;
    }

    private string GetEntityTypeName(EntityType type) => type switch
    {
        EntityType.Character => "角色",
        EntityType.Faction => "势力",
        EntityType.Item => "物品",
        EntityType.Scene => "场景",
        _ => "实体"
    };
}

<style>
    .world-building {
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }

    .alert-warning {
        padding: 16px 18px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: #0b0b0b;
        color: #f0f0f0;
    }
    
    .alert-warning a {
        color: #ffffff;
        text-decoration: underline;
    }

    .split-container {
        display: flex;
        gap: 18px;
    }

    .section-box {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 20px;
    }

    .section-textarea {
        min-height: 240px;
    }

    .section-box textarea:disabled {
        opacity: 0.52;
        cursor: not-allowed;
    }

    .controls {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        margin-top: 16px;
    }

    .right-controls {
        display: flex;
        gap: 10px;
    }

    .icon-btn,
    .ai-btn,
    .btn-add,
    .btn-save,
    .btn-delete,
    .btn-add-minor,
    .btn-remove {
        min-height: 40px;
    }

    .loading-overlay {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background-color: rgba(8, 8, 8, 0.96);
        color: #f5f5f5;
        padding: 10px 20px;
        border-radius: 999px;
        border: 1px solid #262626;
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.45);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cards-section {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .entity-category {
        padding: 20px;
    }

    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        border-bottom: 1px solid #1d1d1d;
        padding-bottom: 12px;
    }

    .category-header h4 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 14px;
    }

    .entity-card {
        background: #101010;
        border: 1px solid #202020;
        border-radius: 16px;
        padding: 16px;
        cursor: pointer;
        transition: background-color 120ms ease, border-color 120ms ease, transform 120ms ease;
        min-height: 104px;
        display: flex;
        flex-direction: column;
    }

    .entity-card:hover {
        transform: translateY(-1px);
        background: #151515;
        border-color: #3a3a3a;
    }

    .card-name {
        font-weight: 700;
        margin-bottom: 8px;
        font-size: 16px;
        letter-spacing: -0.02em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-summary {
        font-size: 13px;
        color: #9f9f9f;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .modal-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(0,0,0,0.78);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-content {
        background-color: #090909;
        border-radius: 22px;
        width: 560px;
        max-width: 90vw;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        border: 1px solid #262626;
        box-shadow: 0 24px 60px rgba(0,0,0,0.52);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 22px;
        border-bottom: 1px solid #1d1d1d;
    }

    .modal-header h3 {
        margin: 0;
        font-size: 18px;
        letter-spacing: -0.02em;
    }

    .close-btn {
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid #2a2a2a;
        background: #0f0f0f;
        color: #d9d9d9;
        cursor: pointer;
    }

    .modal-body {
        padding: 20px 22px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group label {
        font-size: 13px;
        font-weight: 600;
        color: #cfcfcf;
    }

    .desc-row {
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

    .desc-row textarea { flex: 1; }

    .btn-add-minor {
        align-self: flex-start;
    }

    .modal-footer {
        padding: 18px 22px;
        border-top: 1px solid #1d1d1d;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    @@media (max-width: 900px) {
        .split-container {
            flex-direction: column;
        }

        .controls,
        .category-header,
        .desc-row {
            flex-direction: column;
            align-items: stretch;
        }

        .right-controls {
            width: 100%;
        }

        .right-controls > * {
            flex: 1;
        }
    }
</style>
