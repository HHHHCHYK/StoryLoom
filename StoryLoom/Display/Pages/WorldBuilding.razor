    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 20px;
        border-bottom: 1px solid #333;
    }

    .modal-header h3 { margin: 0; color: #dcdcaa; }

    .close-btn {
        background: none;
        border: none;
        color: #d4d4d4;
        font-size: 18px;
        cursor: pointer;
    }

    .modal-body {
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .form-group label {
        color: #9cdcfe;
        font-size: 13px;
        font-weight: bold;
    }

    .form-group input, .form-group textarea {
        background-color: #252526;
        color: #d4d4d4;
        border: 1px solid #3e3e42;
        padding: 8px;
        border-radius: 4px;
        font-family: inherit;
    }

    .desc-row {
        display: flex;
        gap: 10px;
        margin-bottom: 5px;
        align-items: flex-start;
    }

    .desc-row textarea { flex: 1; }

    .btn-remove {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 16px;
        padding: 5px;
    }

    .btn-add-minor {
        background-color: #333;
        color: #d4d4d4;
        border: 1px dashed #555;
        padding: 6px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
        align-self: flex-start;
